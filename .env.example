SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (HTTPS) — set when deploying behind Nginx + SSL
# DEBUG=False
# ALLOWED_HOSTS=hiremeapp.duckdns.org,72.61.106.38,localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=https://hiremeapp.duckdns.org

# PostgreSQL (omit to use SQLite for local dev)
# Note: URL-encode special characters in password (@ becomes %40)
DATABASE_URL=postgresql://admin:password%40123@localhost:5432/hirelens

# Gemini API (required for AI resume analysis)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Email — candidate status-change notifications
# Dev default prints emails to the console. For production, use SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=your_app_password
# DEFAULT_FROM_EMAIL=HireLens <no-reply@yourdomain.com>
# SEND_APPLICATION_EMAILS=True
